# Copier en .env et adapter. Sur Coolify, definir ces variables dans l'UI.

# PostgreSQL
POSTGRES_DB=bank
POSTGRES_USER=bank
POSTGRES_PASSWORD=change-me

# API
API_PORT=8080

# Frontend (web) — port hote en local uniquement (override). Sur Coolify,
# le reverse-proxy route le domaine vers le port 80 du service web.
WEB_PORT=3000
JWT_SECRET=change-me-please-a-long-random-secret-at-least-32-bytes
JWT_TTL_SECONDS=3600
JWT_ISSUER=banking-api
SEED_ENABLED=true
